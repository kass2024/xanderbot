# Copy to .env (local) or .env.linux (VPS). Never commit files with real secrets.
#
# LOCAL WINDOWS (this PC):
#   copy .env.example .env  → fill values → copy .env .env.local
#   APP_ENV=local, APP_DEBUG=true, APP_URL=http://127.0.0.1:8000
#   XANDER_PHP_PATH=C:/xampp/htdocs/Xander
#   SESSION_SECURE_COOKIE=false
#   DB_USERNAME=root (typical XAMPP)
#
# LINUX VPS (xanderbot.site):
#   copy .env.linux to server as .env  OR  scripts/env-use-linux.sh
#   APP_ENV=production, no XANDER_PHP_PATH
#   scripts/env-use-linux.ps1  (on Windows, before SFTP upload)

APP_NAME="Xander"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

API_TIMEOUT=30
API_RETRY_ATTEMPTS=2
ADMIN_EMAIL=support@xanderglobalscholars.com

CHAT_AGENT_PRIORITY=4,5
CHAT_AGENT_TIMEOUT=60
CHAT_BOT_FALLBACK_TIMEOUT=300
CHAT_ENABLE_BOT_FALLBACK=true
CHAT_ENABLE_AGENT_REASSIGNMENT=true

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=Xander
DB_USERNAME=root
DB_PASSWORD=
# Migrations: composer install / deploy runs `php artisan migrate:auto` automatically.
# Manual: php artisan migrate:auto  (local)  |  php artisan migrate:auto --force  (VPS)

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# false = Hello / FAQ replies immediately (no name+email gate first)
CHATBOT_REQUIRE_PROFILE_ONBOARDING=false
CHATBOT_TRANSCRIBE_AUDIO=true
CHATBOT_VOICE_FAQ_REPLIES=false

# Use sync for instant bot replies (same as WABA)
QUEUE_CONNECTION=sync

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"

FB_APP_ID=
FB_APP_SECRET=
FB_REDIRECT_URI=https://xanderbot.site/auth/facebook/callback
FB_GRAPH_VERSION=v22.0

META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=https://xanderbot.site/admin/meta/callback
META_SYSTEM_USER_TOKEN=
META_AD_ACCOUNT_ID=
META_GRAPH_VERSION=v22.0
META_PAGE_ID=
# Numeric Instagram business account ID (@xander_global_scholars). Required for IG ad delivery.
# Find in Meta Business Suite → Accounts → Instagram accounts, or Page → Connected assets.
META_INSTAGRAM_USER_ID=

# Same keys as parrot_mis + cPanel Xander (keep values in sync across all three)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ID=
WHATSAPP_TIMEOUT=30
FFMPEG_BINARY=ffmpeg
META_GRAPH_VERSION=v22.0
WHATSAPP_TRACKING_ENABLED=true
# WHATSAPP_DEFAULT_COUNTRY_CODE=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# NOTE: WhatsApp pre-screening (invite templates, sessions, submissions)
# is handled exclusively by the cPanel Xander project at
# C:\xampp\htdocs\Xander. xanderbot is the chatbot only and does not
# forward inbound WhatsApp messages to pre-screening.

WHATSAPP_TRACKING_ENABLED=true

SESSION_SECURE_COOKIE=false
