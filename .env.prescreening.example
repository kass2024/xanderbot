# Pre-screening on cPanel — add to webhook app .env (same values as cPanel .env)

# Where Meta webhook events are relayed for pre-screening (cPanel)
XANDER_PRESCREENING_URL=https://xanderglobalscholars.com/api/prescreening-inbound.php

# Must match cPanel PRESCREENING_FORWARD_SECRET exactly
PRESCREENING_FORWARD_SECRET=
